      "parameters": {
        "jsCode": "const message = $('Extraer Datos Mensaje').item.json;\nconst tutor = $('Buscar en Hoja Tutores').item.json;\nconst session = $json;\n\nconst telegram_user = message.telegram_user;\nconst texto = (message.texto || '').trim().toLowerCase();\n\nif (!tutor || !tutor.id_tutor) {\n  return [{ json: { registrado: false, telegram_user, error_msg: \"🔴 No estás registrado como tutor en el sistema. Por favor, contacta al administrador.\" } }];\n}\n\nlet pantalla_actual = 'menu_principal';\nlet datos_parciales = '{}';\nconst es_start = (texto === '/start');\n\nif (!es_start && session && session.pantalla_actual) {\n  pantalla_actual = session.pantalla_actual;\n  datos_parciales = session.datos_parciales || '{}';\n}\n\nreturn [{\n  json: {\n    registrado: true,\n    telegram_user,\n    id_tutor: tutor.id_tutor,\n    nombre_tutor: tutor.nombre,\n    pantalla_actual,\n    datos_parciales\n  }\n}];"
      },
