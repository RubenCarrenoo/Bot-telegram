    {
      "parameters": {
        "jsCode": "const { opcion, telegram_user } = $('Interpretar Opcion Menu').item.json;\nconst tutorias = $input.all().map(i => i.json).filter(t => t.id_tutoria);\n\nlet texto = '';\nlet hay = false;\nlet nueva_pantalla = 'menu_principal';\nlet lista_guardar = '[]';\n\nif (opcion === 'confirmar') {\n  const items = tutorias.filter(t => ['Asignada', 'Pendiente'].includes(t.estado));\n  hay = items.length > 0;\n  texto = hay\n    ? 'Elige la tutoría que deseas CONFIRMAR (responde con el número):\\n' +\n      items.map((t, i) => `${i + 1}. Estudiante: ${t.nombre_estudiante || 'Registrado'} | ${t.materia} | ${t.fecha} a las ${t.hora}`).join('\\n')\n    : 'No tienes tutorías pendientes de confirmación.';\n  nueva_pantalla = hay ? 'esperando_confirmacion' : 'menu_principal';\n  lista_guardar = JSON.stringify(items);\n} else if (opcion === 'finalizar') {\n  const items = tutorias.filter(t => t.estado === 'Confirmada');\n  hay = items.length > 0;\n  texto = hay\n    ? 'Elige la tutoría que deseas FINALIZAR (responde con el número):\\n' +\n      items.map((t, i) => `${i + 1}. Estudiante: ${t.nombre_estudiante || 'Registrado'} | ${t.materia} | ${t.fecha}`).join('\\n')\n    : 'No tienes tutorías activas (Confirmadas) para finalizar.';\n  nueva_pantalla = hay ? 'esperando_finalizacion' : 'menu_principal';\n  lista_guardar = JSON.stringify(items);\n} else if (opcion === 'consultar') {\n  texto = tutorias.length\n    ? 'Tus tutorías registradas:\\n' + tutorias.map(t => `- [${t.estado}] ${t.materia} | ${t.fecha} ${t.hora}`).join('\\n')\n    : 'No tienes tutorías en tu historial todavía.';\n  nueva_pantalla = 'menu_principal';\n  hay = false;\n}\n\nreturn [{ json: { texto, hay, nueva_pantalla, lista_guardar, telegram_user } }];"
      },
