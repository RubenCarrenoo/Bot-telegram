        "jsCode": "const { texto, telegram_user } = $('Extraer Datos Mensaje').item.json;\nconst { pantalla_actual, datos_parciales } = $json;\nconst seleccion = parseInt(texto.trim(), 10);\nconst datosSesion = datos_parciales ? JSON.parse(datos_parciales) : {};\nconst lista = datosSesion.lista ? JSON.parse(datosSesion.lista) : [];\nconst valido = !isNaN(seleccion) && seleccion > 0 && seleccion <= lista.length;\n\nif (!valido) {\n  const error_msg = pantalla_actual === 'esperando_confirmacion'\n    ? 'Opción inválida. Responde con un número válido de la lista de tutorías pendientes.'\n    : 'Opción inválida. Responde con un número de la lista de tutorías activas.';\n  return [{ json: { valido, telegram_user, error_msg } }];\n}\n\nconst tutoria = lista[seleccion - 1];\nconst { id_tutoria, id_disponibilidad, id_estudiante, materia, fecha, hora } = tutoria;\n\nlet nuevo_estado_tutoria = '';\nlet nuevo_estado_disp = '';\nlet msg_estudiante = '';\nlet msg_tutor = '';\n\nif (pantalla_actual === 'esperando_confirmacion') {\n  nuevo_estado_tutoria = 'Confirmada';\n  nuevo_estado_disp = 'Ocupado';\n  msg_estudiante = `✨ ¡Tu tutoría ha sido confirmada!\\n\\nMateria: ${materia}\\nFecha: ${fecha}\\nHora: ${hora}\\n\\nTu tutor te espera. ¡Prepárate bien!`;\n  msg_tutor = `✅ Tutoría confirmada con éxito. Hemos notificado al estudiante por ti.`;\n} else if (pantalla_actual === 'esperando_finalizacion') {\n  nuevo_estado_tutoria = 'Finalizada';\n  nuevo_estado_disp = 'Libre';\n  msg_estudiante = `🔔 Tu tutoría de ${materia} ha sido completada y finalizada por tu tutor. ¡Gracias por tu dedicación!`;\n  msg_tutor = `🎉 Tutoría finalizada con éxito. El bloque horario vuelve a estar Libre para agendar.`;\n}\n\nreturn [{\n  json: {\n    valido,\n    id_tutoria,\n    id_disponibilidad,\n    id_estudiante,\n    materia,\n    fecha,\n    hora,\n    telegram_user,\n    pantalla_actual,\n    nuevo_estado_tutoria,\n    nuevo_estado_disp,\n    msg_estudiante,\n    msg_tutor\n  }\n}];"
      },
